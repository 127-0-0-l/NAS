<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NAS</title>
    <link href="/Content/font-awesome-4.7.0/css/font-awesome.min.css" rel="stylesheet">
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <header>
        <h5>NAS</h5>
        <div id="theme-toggle" onclick="toggleTheme()">
            <i id="theme-toggle-icon" class="fa"></i>
        </div>
    </header>
    <div id="page-content">
        <div id="sidebar-menu">
            <a id="menu-bt-index" class="menu-active">Index</a>
            <a id="menu-bt-about">about</a>
            <a id="menu-bt-contact">contact</a>
        </div>
        <div id="tab-content">
            @RenderBody()
        </div>
        <div id="sidebar-monitor">
            <div id="monitor-log"></div>
            <div id="monitor-queue"></div>
        </div>
    </div>
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/Scripts/MyScripts/index.js")
    @Scripts.Render("~/Scripts/MyScripts/themes.js")
    @RenderSection("scripts", required: false)
</body>
</html>
